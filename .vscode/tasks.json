{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build active file (+ library)",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-Isrc/include",
                "-Wall",
                "-g",
                "${file}",
                "src/CTerminalPlotLib.c",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe",
                "-lm"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$gcc"],
            "group": { "kind": "build", "isDefault": true },
            "detail": "Compile the open .c together with the CTerminalPlot library."
        },
        {
            "label": "make (build library + examples)",
            "type": "shell",
            "command": "make",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "make test",
            "type": "shell",
            "command": "make test",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "test",
            "problemMatcher": ["$gcc"]
        }
    ]
}
